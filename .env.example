# ---- Anthropic (for AI-generated captions) ----
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ---- LinkedIn ----
# Access token from your LinkedIn Developer App (OAuth 2.0, 3-legged).
# Expires every 60 days -- see README for how to refresh it.
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token

# Author URN for the account posting.
# Personal profile:  urn:li:person:XXXXXXXX
# Company page:      urn:li:organization:XXXXXXXX
LINKEDIN_AUTHOR_URN=urn:li:person:XXXXXXXX

# LinkedIn API version header, format YYYYMM (bump this every few months)
LINKEDIN_API_VERSION=202504

# ---- Schedule ----
# 24-hour format, in the timezone below
POST_HOUR=9
POST_MINUTE=0
TIMEZONE=Asia/Kolkata
